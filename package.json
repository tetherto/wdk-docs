{
  "name": "wdk-docs",
  "version": "1.0.0",
  "description": "Official documentation for the Wallet Development Kit (WDK) by Tether",
  "private": true,
  "scripts": {
    "build:og": "DOCS_SEO_QUIET_GENERATED=1 tsx scripts/generate-og.mts",
    "build:search": "node scripts/generate-search-index.mjs",
    "prebuild": "npm run build:search && npm run build:og",
    "prebuild:static": "npm run build:search && npm run build:og",
    "predev": "npm run build:search",
    "build": "DOCS_SEO_QUIET_GENERATED=1 NODE_OPTIONS='--import tsx/esm' next build && DOCS_SEO_QUIET_GENERATED=1 NODE_OPTIONS='--import tsx/esm' npx @vahor/next-broken-links",
    "build:static": "DOCS_SEO_QUIET_GENERATED=1 NODE_OPTIONS='--import tsx/esm' next build && DOCS_SEO_QUIET_GENERATED=1 NODE_OPTIONS='--import tsx/esm' npx @vahor/next-broken-links",
    "dev": "DOCS_SEO_QUIET_GENERATED=1 NODE_OPTIONS='--import tsx/esm' next dev --turbo -p 3001",
    "start": "next start",
    "serve": "serve dist -p 8080",
    "postinstall": "tsx node_modules/fumadocs-mdx/dist/bin.js",
    "check-links": "node scripts/check-links.js",
    "check:links": "node scripts/check-links.mjs",
    "check:meta": "node scripts/check-meta.mjs",
    "quality": "npm run check:meta && npm run check:links && npm run build"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.29",
    "@ai-sdk/react": "^2.0.118",
    "@icons-pack/react-simple-icons": "^13.8.0",
    "@inkeep/cxkit-react": "^0.5.111",
    "@next/third-parties": "^16.2.6",
    "@orama/orama": "^3.1.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-presence": "^1.1.5",
    "@takumi-rs/image-response": "^1.0.0-rc.14",
    "@tetherto/docs-seo-core": "^1.0.1",
    "@tetherto/docs-seo-next": "^1.0.1",
    "@tetherto/docs-seo-og": "^1.1.1",
    "@tetherto/docs-seo-schema": "^1.1.0",
    "ai": "^5.0.116",
    "class-variance-authority": "^0.7.1",
    "dotenv": "^17.2.3",
    "fumadocs-core": "^16.3.2",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-ui": "^16.3.2",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "katex": "^0.16.27",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.15.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.3.3",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vahor/next-broken-links": "^0.4.1",
    "glob": "^11.0.3",
    "postcss": "^8.5.6",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "remark-validate-links": "^13.1.0",
    "serve": "^14.2.5",
    "tailwindcss": "^4.1.13",
    "typedoc": "^0.28.17",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.10.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2",
    "unified": "^11.0.2",
    "unist-util-visit": "^5.0.0"
  },
  "overrides": {
    "lodash-es": "^4.18.1",
    "postcss": "$postcss"
  }
}
