# Copy to `.env.local` and fill in local values.
# `.env.local` is gitignored.

# Required to install @tetherto/* packages from GitHub Packages.
# `.npmrc` reads this as ${GITHUB_TOKEN} at install time; export it in your
# shell before running `npm install`, or source `.env.local`.
#
# CI maps the package-read PAT, GitHub's automatic token, or a PAT into this
# same variable name so npm auth follows the same pattern as Pear docs.
GITHUB_TOKEN=

# Required for production SEO: canonical URLs, sitemap, Open Graph, Twitter.
# Optional locally: defaults to http://localhost:8080 in src/lib/seo-config.ts.
NEXT_PUBLIC_DOCS_ORIGIN=https://docs.wdk.tether.io
# NEXT_PUBLIC_SITE_URL=https://docs.wdk.tether.io

# Inkeep API key for search and chat functionality.
NEXT_PUBLIC_INKEEP_API_KEY=your_inkeep_api_key_here

# Google Tag Manager container ID.
NEXT_PUBLIC_GTM_ID=GTM-M8RR2ZBL

# Optional SEO settings.
# NEXT_PUBLIC_DOCS_PUBLISHER_LOGO_URL=https://your-cdn.example/wdk-logo.png
# SKIP_OG_BUILD=1
# DOCS_OG_SITE_LABEL=WDK
# DOCS_OG_CONCURRENCY=3
# DOCS_SEO_QUIET_GENERATED=1
# DOCS_SEO_SILENT=1
